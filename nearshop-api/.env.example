# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nearshop
# DigitalOcean (production):
# DATABASE_URL=postgresql+asyncpg://doadmin:PASSWORD@db-host.ondigitalocean.com:25060/defaultdb?ssl=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))" ──
JWT_SECRET_KEY=change-me-to-a-random-32-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMS / OTP ─────────────────────────────────────────────────────────────────
OTP_SMS_API_KEY=your-sms-api-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Cloudflare R2 (media uploads) ────────────────────────────────────────────
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=nearshop-media

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── CORS — comma-separated allowed frontend origins (production) ──────────────
# ALLOWED_ORIGINS=https://nearshop.yourdomain.com,https://www.nearshop.yourdomain.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
