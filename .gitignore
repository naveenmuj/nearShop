# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
venv/
.venv/
*.egg

# ── Environment (never commit secrets) ───────────────────────────────────────
.env
.env.local
.env.production
# .env.example and .env.production template ARE committed (no real secrets)

# ── Firebase (private keys — never commit) ────────────────────────────────────
firebase-service-account.json
*-service-account.json

# ── Scripts with hardcoded credentials ───────────────────────────────────────
nearshop-api/scripts/migrate_to_cloud.py

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output ──────────────────────────────────────────────────────────────
nearshop-web/dist/
nearshop-web/build/
nearshop-mobile/builds/*.apk
*.apk

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Test coverage ─────────────────────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*

# ── Claude Code internal ──────────────────────────────────────────────────────
.claude/
